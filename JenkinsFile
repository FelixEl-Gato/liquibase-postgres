pipeline {
    agent any

    environment {
        LIQUIBASE_HOME = '/var/jenkins_home/liquibase'
        DB_PASSWORD    = credentials('pg-password')
        WORKSPACE_PATH = '/var/jenkins_home/workspace/liquibase-postgres'
    }

    stages {

        stage('Instalar Liquibase') {
            steps {
                sh '''
                    if [ ! -f $LIQUIBASE_HOME/liquibase ]; then
                        echo "Descargando Liquibase..."
                        curl -L https://github.com/liquibase/liquibase/releases/download/v5.0.2/liquibase-5.0.2.tar.gz -o /tmp/liquibase.tar.gz
                        mkdir -p $LIQUIBASE_HOME
                        tar -xzf /tmp/liquibase.tar.gz -C $LIQUIBASE_HOME
                        rm /tmp/liquibase.tar.gz
                    else
                        echo "Liquibase ya está instalado"
                    fi
                '''
            }
        }

        stage('Instalar Driver PostgreSQL') {
            steps {
                sh '''
                    if [ ! -f $LIQUIBASE_HOME/lib/postgresql-42.7.3.jar ]; then
                        curl -L https://jdbc.postgresql.org/download/postgresql-42.7.3.jar -o $LIQUIBASE_HOME/lib/postgresql-42.7.3.jar
                        echo "Driver instalado"
                    else
                        echo "Driver ya existe"
                    fi
                '''
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'master', url: 'https://github.com/FelixEl-Gato/liquibase-postgres.git'
            }
        }

        stage('Liquibase Status') {
            steps {
                sh '''
                    $LIQUIBASE_HOME/liquibase \
                        --url=jdbc:postgresql://gondola.proxy.rlwy.net:15118/railway \
                        --username=postgres \
                        --password=$DB_PASSWORD \
                        --changeLogFile=changelog/db.changelog-master.xml \
                        --searchPath=$WORKSPACE_PATH \
                        status
                '''
            }
        }

        stage('Liquibase Update') {
            steps {
                sh '''
                    $LIQUIBASE_HOME/liquibase \
                        --url=jdbc:postgresql://gondola.proxy.rlwy.net:15118/railway \
                        --username=postgres \
                        --password=$DB_PASSWORD \
                        --changeLogFile=changelog/db.changelog-master.xml \
                        --searchPath=$WORKSPACE_PATH \
                        update
                '''
            }
        }

    }

    post {
        success {
            echo '✅ Migración aplicada correctamente'
        }
        failure {
            echo '❌ Error en la migración'
        }
    }
}